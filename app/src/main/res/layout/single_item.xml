<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_height="wrap_content">

<!--    below is a cardview -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="10dp"
        android:layout_margin="10dp"
        app:cardElevation="15dp"
        app:cardCornerRadius="15dp">

<!--        below is a linear layout that dedicates ho the contents wii be alligned-->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="10dp"
            android:background="#ffffff">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:id="@+id/product_name"
                android:text="product name"
                android:textSize="25sp"
                android:textStyle="bold"
                android:textAlignment="center"
                android:textColor="#0000FF"
                android:fontFamily="sans-serif"/>

<!--            below is our product image -->
            <ImageView
                android:id="@+id/product_photo"
                android:layout_width="match_parent"
                android:layout_height="250dp"
                android:src="@drawable/sokogarden"
                android:scaleType="centerCrop"
                android:layout_marginTop="5dp"/>

<!--            below is a textview of the product cost-->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:id="@+id/product_cost"
                android:text="ksh 500"
                android:layout_marginTop="20dp"
                android:textStyle="bold|italic"
                android:textSize="20sp"
                android:textColor="#0000FF"
                />

<!--            below is the textview of the product description-->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:id="@+id/product_description"
                android:text="product description"
                android:textSize="20dp"
                android:textColor="#0000FF"
                android:layout_marginTop="3dp"/>

<!--            below is the purchase button -->
            <Button
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:id="@+id/purchase_button"
                android:text="Purchase Now"
                android:textSize="20dp"
                android:layout_marginTop="20dp"
                android:backgroundTint="#6200EE"
                android:textColor="#ffffff"/>


        </LinearLayout>
    </androidx.cardview.widget.CardView>

</LinearLayout>